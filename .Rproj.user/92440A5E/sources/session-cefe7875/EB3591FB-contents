clinical_vars <- c("LVEF", "NTproBNP", "CRP", "TropT")

for (var in clinical_vars) {

  
  cat_col <- paste0(var, "_cat_median")
  
  # exact median value for the current variable is extracted
  var_median <- calculated_medians[[var]]
  
  cat("\n-----------------------------------\n")
  cat("Variable:", var, "\n")
  cat("Calculated Median:", var_median, "\n")
  
  # !!sym() conversion of the string names into variables
  p <- ggplot(Samples, aes(x = !!sym(cat_col), y = !!sym(var), fill = !!sym(cat_col))) +
    geom_boxplot(alpha = 0.6, na.rm = TRUE, outlier.shape = NA) +
    geom_jitter(width = 0.15, size = 2, alpha = 0.8, na.rm = TRUE, color = "black") +
    geom_hline(yintercept = var_median, linetype = "dashed", color = "black", linewidth = 1) +
    scale_fill_manual(values = c("High" = "darkblue", "Low" = "grey")) +
    theme_classic() +
    labs(
      title = paste(var),
      subtitle = paste("median:", round(var_median, 2)),
      x = "Median Split Group",
      y = paste(var, "Value")) +
    theme(
      legend.position = "none",
      plot.title = element_text(face = "bold", size = 14),
      axis.text = element_text(size = 12))
  
  # Display the plot
  print(p)
}

```

## Gene ontology of clinical variables: LVEF, NTProBNP, TropT and CRP accross all clusters 
```{r, echo = F}

clinical_vars <- c("LVEF", "NTproBNP", "CRP", "TropT")

for (var in clinical_vars) {
  
  cat("\n======================================================\n")
  cat("Running DE and GO analysis for:", var, "Median Split\n")
  
  cat_col <- paste0(var, "_cat_median")
  Idents(seuratM) <- cat_col
  
  # Run FindAllMarkers
  DEGenes <- suppressWarnings(
    FindAllMarkers(seuratM, only.pos = TRUE, logfc.threshold = 0.2, verbose = FALSE)) %>% dplyr::filter(p_val_adj < 0.01)
  
  DEGenes <- DEGenes %>% 
    mutate(Gene = gene) %>%
    mutate(gene = gsub("^.*\\.", "", Gene)) %>%
    mutate(EnsID = gsub("\\..*", "", Gene))
  
  # Target the worse clinical outcome
  target_cluster <- ifelse(var == "LVEF", "Low", "High")
  DEGenes_target <- DEGenes %>% filter(cluster == target_cluster)
  
  cat("Found", nrow(DEGenes_target), "significant DEGs for", var, "(", target_cluster, ")\n")
  
  # Run GO Enrichment
  if (nrow(DEGenes_target) > 0) {
    
    ego <- enrichGO(
      gene          = unique(DEGenes_target$EnsID),
      OrgDb         = org.Hs.eg.db,
      keyType       = 'ENSEMBL',
      ont           = "BP",
      pAdjustMethod = "BH",
      pvalueCutoff  = 0.05,
      qvalueCutoff  = 0.05)
    
    if (!is.null(ego) && nrow(as.data.frame(ego)) > 0) {
      egoe <- setReadable(ego, OrgDb = org.Hs.eg.db)
      
      p <- barplot(egoe,  drop = TRUE, showCategory = 10, title = paste("GO Pathways:", var, "-", target_cluster),
        font.size = 10)
      
      print(p)
      
## pause
      Sys.sleep(2)
      
    } else {
      cat("--> No significant GO terms found for", var, "\n")
    }
  } else {
    cat("--> Skipping GO analysis for", var, "due to 0 DEGs.\n")
  }
}



